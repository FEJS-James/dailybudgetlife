---
const today = new Date();
---

<footer>
	<div class="footer-content">
		<p>&copy; {today.getFullYear()} Daily Budget Life. All rights reserved.</p>
		<p class="tagline">Practical money tips for real life.</p>
	</div>
</footer>
<style>
	footer {
		padding: 3em 1.5em;
		background: rgb(var(--gray-dark));
		color: rgba(255, 255, 255, 0.7);
		text-align: center;
		margin-top: 2em;
	}
	.footer-content { max-width: 960px; margin: 0 auto; }
	footer p { margin: 0.3em 0; font-size: 0.9em; }
	.tagline { font-size: 0.8em; opacity: 0.6; }
</style>
