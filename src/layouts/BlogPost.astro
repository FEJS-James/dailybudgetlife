---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "Article",
	"headline": title,
	"description": description,
	"datePublished": pubDate.toISOString(),
	...(updatedDate && { "dateModified": updatedDate.toISOString() }),
	"url": canonicalURL,
	"publisher": {
		"@type": "Organization",
		"name": SITE_TITLE,
		"logo": { "@type": "ImageObject", "url": new URL("/favicon.svg", Astro.site) }
	},
	"mainEntityOfPage": { "@type": "WebPage", "@id": canonicalURL }
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<BaseHead title={`${title} — ${SITE_TITLE}`} description={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;0,9..40,800;0,9..40,900;1,9..40,400;1,9..40,500&display=swap" rel="stylesheet">
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
		<style>
			body { font-family: 'DM Sans', system-ui, sans-serif; }
		</style>
	</head>
	<body class="bg-stone-50 text-gray-900 antialiased">

		<!-- Nav -->
		<nav class="sticky top-0 z-50 bg-stone-50/80 backdrop-blur-xl border-b border-stone-200/60">
			<div class="max-w-6xl mx-auto px-6 lg:px-8 py-4 flex items-center justify-between">
				<a href="/" class="text-2xl font-black tracking-tight">
					<span class="text-gray-900">Daily</span><span class="text-emerald-600">Budget</span><span class="text-gray-900">Life</span>
				</a>
				<div class="flex items-center gap-6 text-sm font-medium text-stone-500">
					<a href="/" class="hover:text-emerald-600 transition-colors duration-200">Home</a>
					<a href="/blog" class="hover:text-emerald-600 transition-colors duration-200">Articles</a>
					<a href="/about" class="hover:text-emerald-600 transition-colors duration-200">About</a>
				</div>
			</div>
		</nav>

		<main class="max-w-3xl mx-auto px-6 lg:px-8 py-12 md:py-16">
			<article>
				<!-- Breadcrumb -->
				<div class="flex items-center gap-2 text-sm text-stone-400 mb-8">
					<a href="/" class="hover:text-emerald-600 transition-colors">Home</a>
					<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
					<a href="/blog" class="hover:text-emerald-600 transition-colors">Articles</a>
					<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
					<span class="text-stone-600 truncate max-w-xs">{title}</span>
				</div>

				<header class="mb-12">
					<div class="flex items-center gap-3 mb-5">
						<span class="text-sm text-emerald-600 font-semibold">
							<FormattedDate date={pubDate} />
						</span>
						{updatedDate && (
							<span class="text-sm text-stone-400">
								· Updated <FormattedDate date={updatedDate} />
							</span>
						)}
						<span class="text-stone-300">·</span>
						<span class="text-sm text-stone-400">7 min read</span>
					</div>
					<h1 class="text-3xl md:text-4xl lg:text-5xl font-black text-gray-900 leading-[1.15] tracking-tight mb-5">{title}</h1>
					<p class="text-lg md:text-xl text-stone-500 leading-relaxed">{description}</p>
					<!-- Green accent gradient -->
					<div class="mt-8 h-1 w-24 bg-gradient-to-r from-emerald-500 via-emerald-400 to-teal-300 rounded-full"></div>
				</header>

				<div class="prose max-w-none text-gray-700 leading-[1.85]">
					<slot />
				</div>

				<!-- Post footer CTA -->
				<div class="mt-16 bg-gradient-to-br from-emerald-50 to-teal-50/50 rounded-2xl p-8 md:p-10 border border-emerald-100">
					<h3 class="text-xl font-bold text-gray-900 mb-3">Enjoyed this article?</h3>
					<p class="text-stone-500 mb-6 leading-relaxed">Check out more practical money tips and budgeting guides on our blog.</p>
					<a href="/blog" class="inline-flex items-center gap-2 bg-emerald-600 text-white font-semibold px-6 py-3 rounded-full hover:bg-emerald-700 transition-all duration-200 hover:shadow-lg hover:shadow-emerald-600/20 text-sm">
						Browse All Articles
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
					</a>
				</div>
			</article>
		</main>

		<!-- Footer -->
		<footer class="bg-stone-900 text-stone-400 mt-20">
			<div class="max-w-6xl mx-auto px-6 lg:px-8 py-16">
				<div class="grid md:grid-cols-3 gap-10 mb-12">
					<div>
						<a href="/" class="text-2xl font-black text-white mb-4 block">Daily<span class="text-emerald-400">Budget</span>Life</a>
						<p class="text-stone-500 text-sm leading-relaxed">Practical money tips for real life.</p>
					</div>
					<div>
						<h4 class="font-bold text-stone-300 mb-4 text-sm uppercase tracking-wider">Navigate</h4>
						<div class="flex flex-col gap-2.5">
							<a href="/" class="text-sm hover:text-emerald-400 transition-colors">Home</a>
							<a href="/blog" class="text-sm hover:text-emerald-400 transition-colors">Articles</a>
							<a href="/about" class="text-sm hover:text-emerald-400 transition-colors">About</a>
						</div>
					</div>
					<div>
						<h4 class="font-bold text-stone-300 mb-4 text-sm uppercase tracking-wider">Popular Topics</h4>
						<div class="flex flex-wrap gap-2">
							{['Budgeting', 'Saving', 'Apps', 'Investing'].map(t => (
								<span class="text-xs bg-stone-800 text-stone-400 px-3 py-1.5 rounded-full">{t}</span>
							))}
						</div>
					</div>
				</div>
				<div class="border-t border-stone-800 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
					<p class="text-xs text-stone-600">© 2026 DailyBudgetLife. All rights reserved.</p>
					<p class="text-xs text-stone-600">Built with care for your financial future.</p>
				</div>
			</div>
		</footer>
	</body>
</html>
