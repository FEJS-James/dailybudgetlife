---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "Blog",
	"name": `Articles — ${SITE_TITLE}`,
	"description": SITE_DESCRIPTION,
	"url": new URL("/blog", Astro.site),
	"publisher": { "@type": "Organization", "name": SITE_TITLE }
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<BaseHead title={`Articles — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;0,9..40,800;0,9..40,900;1,9..40,400&display=swap" rel="stylesheet">
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
		<style>body { font-family: 'DM Sans', system-ui, sans-serif; }</style>
	</head>
	<body class="bg-stone-50 text-gray-900 antialiased">

		<!-- Nav -->
		<nav class="sticky top-0 z-50 bg-stone-50/80 backdrop-blur-xl border-b border-stone-200/60">
			<div class="max-w-6xl mx-auto px-6 lg:px-8 py-4 flex items-center justify-between">
				<a href="/" class="text-2xl font-black tracking-tight">
					<span class="text-gray-900">Daily</span><span class="text-emerald-600">Budget</span><span class="text-gray-900">Life</span>
				</a>
				<div class="flex items-center gap-6 text-sm font-medium text-stone-500">
					<a href="/" class="hover:text-emerald-600 transition-colors duration-200">Home</a>
					<a href="/blog" class="text-emerald-600 font-semibold">Articles</a>
					<a href="/about" class="hover:text-emerald-600 transition-colors duration-200">About</a>
				</div>
			</div>
		</nav>

		<main>
			<!-- Header -->
			<section class="relative overflow-hidden bg-gradient-to-br from-stone-100 via-stone-50 to-emerald-50/30">
				<div class="absolute top-0 right-0 w-72 h-72 bg-emerald-200/15 rounded-full blur-3xl"></div>
				<div class="max-w-6xl mx-auto px-6 lg:px-8 py-16 md:py-20">
					<span class="text-emerald-600 font-bold text-sm uppercase tracking-wider mb-3 block">Our Blog</span>
					<h1 class="text-3xl md:text-5xl font-black tracking-tight mb-4">All Articles</h1>
					<p class="text-stone-500 text-lg max-w-xl leading-relaxed">Practical guides and tips to help you master your money and build lasting wealth.</p>
				</div>
			</section>

			<!-- Category pills -->
			<section class="max-w-6xl mx-auto px-6 lg:px-8 py-8 border-b border-stone-200/60">
				<div class="flex flex-wrap gap-2">
					<span class="bg-emerald-600 text-white px-4 py-2 rounded-full text-sm font-semibold cursor-default">All</span>
					{['Budgeting', 'Saving Money', 'Apps & Tools', 'Investing', 'Side Hustles'].map(cat => (
						<span class="bg-white text-stone-600 border border-stone-200 px-4 py-2 rounded-full text-sm font-medium hover:border-emerald-300 hover:text-emerald-700 hover:bg-emerald-50/50 transition-all duration-200 cursor-default">{cat}</span>
					))}
				</div>
			</section>

			<!-- Posts — vertical list -->
			<section class="max-w-6xl mx-auto px-6 lg:px-8 py-12 md:py-16">
				<div class="space-y-5">
					{posts.map((post, i) => {
						const accents = ['border-l-emerald-500', 'border-l-teal-400', 'border-l-cyan-500', 'border-l-amber-400'];
						return (
							<a href={`/blog/${post.id}/`} class={`group block bg-white rounded-2xl border border-stone-200/80 border-l-4 ${accents[i % accents.length]} hover:border-stone-300 transition-all duration-300 hover:shadow-xl hover:shadow-stone-900/5 hover:-translate-y-0.5`}>
								<div class="p-7 md:p-9">
									<div class="flex flex-col md:flex-row md:items-start gap-4 md:gap-8">
										<div class="flex-1">
											<div class="flex flex-wrap items-center gap-3 mb-3">
												{i === 0 && (
													<span class="inline-flex items-center gap-1 bg-emerald-100 text-emerald-700 px-3 py-1 rounded-full text-xs font-bold">
														<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><circle cx="10" cy="10" r="4"/></svg>
														Latest
													</span>
												)}
												<span class="text-xs text-stone-400 font-medium">
													{new Date(post.data.pubDate).toLocaleDateString('en-us', { month: 'long', day: 'numeric', year: 'numeric' })}
												</span>
											</div>
											<h2 class="text-xl md:text-2xl font-bold leading-snug group-hover:text-emerald-700 transition-colors duration-200 mb-3">{post.data.title}</h2>
											<p class="text-stone-500 leading-relaxed mb-4">{post.data.description}</p>
											<span class="inline-flex items-center gap-2 text-emerald-600 font-semibold text-sm group-hover:gap-3 transition-all duration-300">
												Read article
												<svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
											</span>
										</div>
									</div>
								</div>
							</a>
						);
					})}
				</div>
			</section>
		</main>

		<!-- Footer -->
		<footer class="bg-stone-900 text-stone-400">
			<div class="max-w-6xl mx-auto px-6 lg:px-8 py-16">
				<div class="grid md:grid-cols-3 gap-10 mb-12">
					<div>
						<a href="/" class="text-2xl font-black text-white mb-4 block">Daily<span class="text-emerald-400">Budget</span>Life</a>
						<p class="text-stone-500 text-sm leading-relaxed">Practical money tips for real life. No fluff, just actionable advice.</p>
					</div>
					<div>
						<h4 class="font-bold text-stone-300 mb-4 text-sm uppercase tracking-wider">Navigate</h4>
						<div class="flex flex-col gap-2.5">
							<a href="/" class="text-sm hover:text-emerald-400 transition-colors">Home</a>
							<a href="/blog" class="text-sm hover:text-emerald-400 transition-colors">Articles</a>
							<a href="/about" class="text-sm hover:text-emerald-400 transition-colors">About</a>
						</div>
					</div>
					<div>
						<h4 class="font-bold text-stone-300 mb-4 text-sm uppercase tracking-wider">Popular Topics</h4>
						<div class="flex flex-wrap gap-2">
							{['Budgeting', 'Saving', 'Apps', 'Investing'].map(t => (
								<span class="text-xs bg-stone-800 text-stone-400 px-3 py-1.5 rounded-full">{t}</span>
							))}
						</div>
					</div>
				</div>
				<div class="border-t border-stone-800 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
					<p class="text-xs text-stone-600">© 2026 DailyBudgetLife. All rights reserved.</p>
					<p class="text-xs text-stone-600">Built with care for your financial future.</p>
				</div>
			</div>
		</footer>
	</body>
</html>
