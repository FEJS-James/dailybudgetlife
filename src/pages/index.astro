---
import BaseHead from '../components/BaseHead.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
		<style>body{font-family:'DM Sans',system-ui,sans-serif}</style>
	</head>
	<body class="bg-stone-50 text-gray-900 antialiased">

		<!-- Nav — centered, clean -->
		<nav class="border-b border-stone-200">
			<div class="max-w-4xl mx-auto px-6 py-5 flex items-center justify-between">
				<a href="/" class="text-xl font-black">Daily<span class="text-emerald-600">Budget</span>Life</a>
				<div class="flex gap-6 text-sm font-medium text-stone-500">
					<a href="/blog" class="hover:text-gray-900 transition">Articles</a>
					<a href="/about" class="hover:text-gray-900 transition">About</a>
				</div>
			</div>
		</nav>

		<main>
			<!-- Hero — centered, typographic -->
			<section class="max-w-4xl mx-auto px-6 pt-20 pb-16 text-center">
				<span class="inline-block bg-emerald-100 text-emerald-700 px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-6">Personal Finance Made Simple</span>
				<h1 class="text-4xl md:text-6xl font-black leading-tight mb-6">Master your money.<br><span class="text-emerald-600">Build your future.</span></h1>
				<p class="text-stone-500 text-lg max-w-xl mx-auto leading-relaxed">Practical budgeting tips, saving strategies, and money management advice that works in real life. No jargon.</p>
			</section>

			<!-- Articles — full-width cards, stacked -->
			<section class="max-w-4xl mx-auto px-6 pb-20">
				<div class="space-y-4">
					{posts.map((post, i) => (
						<a href={`/blog/${post.id}/`} class="group block bg-white rounded-2xl border border-stone-200 hover:border-emerald-300 transition-all duration-300 hover:shadow-lg overflow-hidden">
							<div class="flex flex-col md:flex-row">
								<!-- Color accent block -->
								<div class={`md:w-2 w-full h-2 md:h-auto shrink-0 ${i === 0 ? 'bg-emerald-500' : i === 1 ? 'bg-teal-400' : 'bg-cyan-400'}`}></div>
								<div class="p-7 md:p-8 flex-1">
									<div class="flex items-center gap-3 mb-3">
										{i === 0 && <span class="bg-emerald-100 text-emerald-700 px-2.5 py-0.5 rounded-full text-xs font-bold">Latest</span>}
										<span class="text-xs text-stone-400 font-medium">
											{new Date(post.data.pubDate).toLocaleDateString('en-us', { month: 'long', day: 'numeric', year: 'numeric' })}
										</span>
									</div>
									<h2 class="text-xl md:text-2xl font-bold leading-snug group-hover:text-emerald-700 transition mb-3">{post.data.title}</h2>
									<p class="text-stone-500 leading-relaxed">{post.data.description}</p>
									<span class="inline-block mt-4 text-emerald-600 font-semibold text-sm">Read article →</span>
								</div>
							</div>
						</a>
					))}
				</div>
			</section>

			<!-- Quick tips callout -->
			<section class="bg-emerald-600 text-white">
				<div class="max-w-4xl mx-auto px-6 py-16 md:py-20">
					<div class="grid md:grid-cols-3 gap-8">
						{[
							{ num: '50/30/20', label: 'The golden ratio for budgeting. Needs, wants, savings.' },
							{ num: '$500+', label: 'Average monthly savings with simple habit changes.' },
							{ num: '7 min', label: 'Average read time. Quick wins, real results.' },
						].map(stat => (
							<div class="text-center md:text-left">
								<p class="text-3xl font-black text-white mb-2">{stat.num}</p>
								<p class="text-emerald-100 text-sm leading-relaxed">{stat.label}</p>
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- Topics -->
			<section class="max-w-4xl mx-auto px-6 py-16">
				<h2 class="text-center text-2xl font-bold mb-10">What we write about</h2>
				<div class="grid grid-cols-2 md:grid-cols-4 gap-3">
					{['Budgeting', 'Saving', 'Apps & Tools', 'Investing', 'Debt', 'Side Hustles', 'Frugal Living', 'Money Mindset'].map(topic => (
						<div class="bg-white border border-stone-200 rounded-xl py-4 px-5 text-center text-sm font-semibold text-stone-700 hover:border-emerald-300 hover:text-emerald-700 transition cursor-default">{topic}</div>
					))}
				</div>
			</section>
		</main>

		<footer class="border-t border-stone-200">
			<div class="max-w-4xl mx-auto px-6 py-8 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-stone-400">
				<p>© 2026 DailyBudgetLife — Practical money tips for real life.</p>
				<div class="flex gap-6">
					<a href="/blog" class="hover:text-gray-900 transition">Articles</a>
					<a href="/about" class="hover:text-gray-900 transition">About</a>
				</div>
			</div>
		</footer>
	</body>
</html>
