---
import BaseHead from '../components/BaseHead.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"name": SITE_TITLE,
	"description": SITE_DESCRIPTION,
	"url": Astro.site,
	"publisher": {
		"@type": "Organization",
		"name": SITE_TITLE,
		"logo": { "@type": "ImageObject", "url": new URL("/favicon.svg", Astro.site) }
	}
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<BaseHead title={`${SITE_TITLE} — Practical Money Tips for Real Life`} description={SITE_DESCRIPTION} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;0,9..40,800;0,9..40,900;1,9..40,400;1,9..40,500&display=swap" rel="stylesheet">
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
		<style>
			body { font-family: 'DM Sans', system-ui, sans-serif; }
			@keyframes fade-up { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }
			.animate-fade-up { animation: fade-up 0.7s ease-out both; }
			.animate-fade-up-delay { animation: fade-up 0.7s ease-out 0.15s both; }
			.animate-fade-up-delay-2 { animation: fade-up 0.7s ease-out 0.3s both; }
		</style>
	</head>
	<body class="bg-stone-50 text-gray-900 antialiased">

		<!-- Nav -->
		<nav class="sticky top-0 z-50 bg-stone-50/80 backdrop-blur-xl border-b border-stone-200/60">
			<div class="max-w-6xl mx-auto px-6 lg:px-8 py-4 flex items-center justify-between">
				<a href="/" class="text-2xl font-black tracking-tight">
					<span class="text-gray-900">Daily</span><span class="text-emerald-600">Budget</span><span class="text-gray-900">Life</span>
				</a>
				<div class="flex items-center gap-8">
					<div class="hidden sm:flex items-center gap-6 text-sm font-medium text-stone-500">
						<a href="/blog" class="hover:text-emerald-600 transition-colors duration-200">Articles</a>
						<a href="/about" class="hover:text-emerald-600 transition-colors duration-200">About</a>
					</div>
					<a href="/blog" class="hidden sm:inline-flex items-center gap-2 bg-emerald-600 text-white text-sm font-semibold px-5 py-2.5 rounded-full hover:bg-emerald-700 transition-all duration-200 hover:shadow-lg hover:shadow-emerald-600/20">
						Start Reading
					</a>
					<!-- Mobile links -->
					<div class="sm:hidden flex items-center gap-4 text-sm font-medium text-stone-500">
						<a href="/blog" class="hover:text-emerald-600 transition">Articles</a>
						<a href="/about" class="hover:text-emerald-600 transition">About</a>
					</div>
				</div>
			</div>
		</nav>

		<main>
			<!-- Hero -->
			<section class="relative overflow-hidden">
				<div class="absolute inset-0 bg-gradient-to-br from-emerald-50 via-stone-50 to-amber-50/30"></div>
				<div class="absolute top-20 right-0 w-96 h-96 bg-emerald-200/20 rounded-full blur-3xl"></div>
				<div class="absolute bottom-0 left-10 w-72 h-72 bg-amber-200/20 rounded-full blur-3xl"></div>
				<div class="relative max-w-6xl mx-auto px-6 lg:px-8 pt-16 md:pt-24 pb-20 md:pb-28">
					<div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
						<div>
							<span class="animate-fade-up inline-flex items-center gap-2 bg-emerald-100/80 text-emerald-700 px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-8">
								<svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a8 8 0 100 16 8 8 0 000-16zm1 11H9v-2h2v2zm0-4H9V5h2v4z"/></svg>
								Personal Finance Made Simple
							</span>
							<h1 class="animate-fade-up text-4xl md:text-5xl lg:text-6xl font-black leading-[1.1] mb-6 tracking-tight">
								Take control of<br>your money.
								<span class="text-emerald-600">Build real wealth.</span>
							</h1>
							<p class="animate-fade-up-delay text-stone-500 text-lg md:text-xl leading-relaxed mb-10 max-w-lg">
								Practical budgeting tips, saving strategies, and money management advice that actually works. No jargon. No fluff. Just results.
							</p>
							<div class="animate-fade-up-delay-2 flex flex-wrap gap-4">
								<a href="/blog" class="inline-flex items-center gap-2 bg-emerald-600 text-white font-semibold px-7 py-3.5 rounded-full hover:bg-emerald-700 transition-all duration-200 hover:shadow-xl hover:shadow-emerald-600/25 hover:-translate-y-0.5">
									Read Latest Articles
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
								</a>
								<a href="/about" class="inline-flex items-center gap-2 bg-white text-gray-700 font-semibold px-7 py-3.5 rounded-full border border-stone-200 hover:border-emerald-300 hover:text-emerald-700 transition-all duration-200 hover:shadow-lg">
									Learn More
								</a>
							</div>
						</div>
						<div class="hidden lg:block">
							<div class="relative">
								<div class="absolute -inset-4 bg-gradient-to-br from-emerald-200/40 to-amber-200/40 rounded-3xl blur-2xl"></div>
								<img
									src="https://images.unsplash.com/photo-1579621970563-ebec7560ff3e?w=800&q=80"
									alt="Financial planning and budgeting"
									class="relative rounded-3xl shadow-2xl shadow-stone-900/10 w-full object-cover aspect-[4/3]"
									loading="eager"
								/>
								<!-- Floating stat card -->
								<div class="absolute -bottom-6 -left-6 bg-white rounded-2xl shadow-xl shadow-stone-900/10 p-5 border border-stone-100">
									<div class="flex items-center gap-3">
										<div class="w-10 h-10 bg-emerald-100 rounded-xl flex items-center justify-center">
											<svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
										</div>
										<div>
											<p class="text-xs text-stone-400 font-medium">Avg. monthly savings</p>
											<p class="text-lg font-black text-emerald-600">$500+</p>
										</div>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- Articles — vertical feed -->
			<section class="max-w-6xl mx-auto px-6 lg:px-8 py-16 md:py-24">
				<div class="flex items-end justify-between mb-12">
					<div>
						<span class="text-emerald-600 font-bold text-sm uppercase tracking-wider mb-2 block">Latest Articles</span>
						<h2 class="text-3xl md:text-4xl font-black tracking-tight">Fresh from the blog</h2>
					</div>
					<a href="/blog" class="hidden sm:inline-flex items-center gap-1.5 text-emerald-600 font-semibold text-sm hover:text-emerald-700 transition-colors">
						View all
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
					</a>
				</div>
				<div class="space-y-5">
					{posts.map((post, i) => {
						const colors = ['border-l-emerald-500', 'border-l-teal-400', 'border-l-cyan-500', 'border-l-amber-400'];
						const bgHovers = ['hover:bg-emerald-50/50', 'hover:bg-teal-50/50', 'hover:bg-cyan-50/50', 'hover:bg-amber-50/50'];
						return (
							<a href={`/blog/${post.id}/`} class={`group block bg-white rounded-2xl border border-stone-200/80 border-l-4 ${colors[i % colors.length]} hover:border-stone-300 ${bgHovers[i % bgHovers.length]} transition-all duration-300 hover:shadow-xl hover:shadow-stone-900/5 hover:-translate-y-0.5`}>
								<div class="p-7 md:p-9 flex flex-col md:flex-row md:items-center gap-4 md:gap-8">
									<div class="flex-1">
										<div class="flex flex-wrap items-center gap-3 mb-3">
											{i === 0 && (
												<span class="inline-flex items-center gap-1 bg-emerald-100 text-emerald-700 px-3 py-1 rounded-full text-xs font-bold">
													<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><circle cx="10" cy="10" r="4"/></svg>
													Latest
												</span>
											)}
											<span class="text-xs text-stone-400 font-medium">
												{new Date(post.data.pubDate).toLocaleDateString('en-us', { month: 'long', day: 'numeric', year: 'numeric' })}
											</span>
										</div>
										<h3 class="text-xl md:text-2xl font-bold leading-snug group-hover:text-emerald-700 transition-colors duration-200 mb-3">{post.data.title}</h3>
										<p class="text-stone-500 leading-relaxed text-sm md:text-base line-clamp-2">{post.data.description}</p>
									</div>
									<div class="shrink-0">
										<span class="inline-flex items-center gap-2 text-emerald-600 font-semibold text-sm group-hover:gap-3 transition-all duration-300">
											Read
											<svg class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
										</span>
									</div>
								</div>
							</a>
						);
					})}
				</div>
			</section>

			<!-- Stats section -->
			<section class="relative overflow-hidden bg-emerald-600">
				<div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(255,255,255,0.1),transparent_60%)]"></div>
				<div class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_left,rgba(0,0,0,0.1),transparent_60%)]"></div>
				<div class="relative max-w-6xl mx-auto px-6 lg:px-8 py-20 md:py-24">
					<div class="text-center mb-14">
						<h2 class="text-3xl md:text-4xl font-black text-white tracking-tight mb-3">Numbers that matter</h2>
						<p class="text-emerald-100/70 text-lg">Simple rules, real results.</p>
					</div>
					<div class="grid md:grid-cols-3 gap-8 md:gap-12">
						{[
							{ num: '50/30/20', label: 'The golden ratio for budgeting — needs, wants, and savings.', icon: '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/></svg>' },
							{ num: '$500+', label: 'Average monthly savings with simple habit changes.', icon: '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>' },
							{ num: '7 min', label: 'Average read time. Quick wins, real results.', icon: '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>' },
						].map(stat => (
							<div class="text-center bg-white/10 backdrop-blur-sm rounded-2xl p-8 border border-white/10 hover:bg-white/15 transition-all duration-300">
								<div class="inline-flex items-center justify-center w-14 h-14 bg-white/10 rounded-xl mb-5 text-emerald-200" set:html={stat.icon} />
								<p class="text-4xl md:text-5xl font-black text-white mb-3">{stat.num}</p>
								<p class="text-emerald-100/80 text-sm leading-relaxed">{stat.label}</p>
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- Topics pills -->
			<section class="max-w-6xl mx-auto px-6 lg:px-8 py-20 md:py-24">
				<div class="text-center mb-12">
					<span class="text-emerald-600 font-bold text-sm uppercase tracking-wider mb-2 block">Topics</span>
					<h2 class="text-3xl md:text-4xl font-black tracking-tight">What we write about</h2>
				</div>
				<div class="flex flex-wrap justify-center gap-3 max-w-3xl mx-auto">
					{[
						{ name: 'Budgeting', emoji: '📊' },
						{ name: 'Saving Money', emoji: '🐷' },
						{ name: 'Apps & Tools', emoji: '📱' },
						{ name: 'Investing', emoji: '📈' },
						{ name: 'Debt Freedom', emoji: '🔓' },
						{ name: 'Side Hustles', emoji: '💼' },
						{ name: 'Frugal Living', emoji: '🌿' },
						{ name: 'Money Mindset', emoji: '🧠' },
					].map(topic => (
						<div class="group flex items-center gap-2 bg-white border border-stone-200 rounded-full py-3 px-6 text-sm font-semibold text-stone-600 hover:border-emerald-300 hover:text-emerald-700 hover:bg-emerald-50/50 hover:shadow-md hover:shadow-emerald-600/5 transition-all duration-300 cursor-default hover:-translate-y-0.5">
							<span class="text-base">{topic.emoji}</span>
							{topic.name}
						</div>
					))}
				</div>
			</section>

			<!-- Testimonial -->
			<section class="bg-stone-100/50">
				<div class="max-w-4xl mx-auto px-6 lg:px-8 py-20 md:py-24">
					<div class="relative bg-white rounded-3xl p-10 md:p-14 shadow-sm border border-stone-200/60">
						<svg class="absolute top-8 left-8 w-12 h-12 text-emerald-200/60" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
						<div class="relative">
							<p class="text-xl md:text-2xl font-medium text-gray-700 leading-relaxed mb-8 italic">
								"I was drowning in subscriptions I didn't use and eating out way too much. After reading the 50/30/20 guide here, I restructured everything. Six months later, I have a $3,000 emergency fund for the first time in my life."
							</p>
							<div class="flex items-center gap-4">
								<div class="w-12 h-12 bg-gradient-to-br from-emerald-400 to-teal-500 rounded-full flex items-center justify-center text-white font-bold text-lg">S</div>
								<div>
									<p class="font-bold text-gray-900">Sarah M.</p>
									<p class="text-sm text-stone-500">Reader since January 2026</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- CTA Section -->
			<section class="relative overflow-hidden">
				<div class="absolute inset-0 bg-gradient-to-br from-emerald-600 via-emerald-500 to-teal-500"></div>
				<div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,0.15),transparent_50%)]"></div>
				<div class="absolute top-0 right-0 w-96 h-96 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/3"></div>
				<div class="absolute bottom-0 left-0 w-64 h-64 bg-white/5 rounded-full translate-y-1/3 -translate-x-1/4"></div>
				<div class="relative max-w-4xl mx-auto px-6 lg:px-8 py-20 md:py-28 text-center">
					<div class="inline-flex items-center gap-2 bg-white/15 backdrop-blur-sm px-4 py-1.5 rounded-full text-sm font-semibold text-white/90 mb-8 border border-white/20">
						<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
						100% Free — No Courses, No Upsells
					</div>
					<h2 class="text-3xl md:text-5xl font-black text-white tracking-tight mb-6 leading-tight">
						Start your budget<br>journey today
					</h2>
					<p class="text-emerald-100/80 text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
						Join thousands of readers who are taking control of their finances with practical, no-nonsense advice.
					</p>
					<a href="/blog" class="inline-flex items-center gap-2 bg-white text-emerald-700 font-bold px-8 py-4 rounded-full text-lg hover:bg-emerald-50 transition-all duration-200 hover:shadow-2xl hover:shadow-black/20 hover:-translate-y-0.5">
						Read the Latest Articles
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
					</a>
				</div>
			</section>
		</main>

		<!-- Footer -->
		<footer class="bg-stone-900 text-stone-400">
			<div class="max-w-6xl mx-auto px-6 lg:px-8 py-16">
				<div class="grid md:grid-cols-3 gap-10 mb-12">
					<div>
						<a href="/" class="text-2xl font-black text-white mb-4 block">Daily<span class="text-emerald-400">Budget</span>Life</a>
						<p class="text-stone-500 text-sm leading-relaxed">Practical money tips for real life. Budgeting, saving, investing, and side hustles — no fluff, just actionable advice.</p>
					</div>
					<div>
						<h4 class="font-bold text-stone-300 mb-4 text-sm uppercase tracking-wider">Navigate</h4>
						<div class="flex flex-col gap-2.5">
							<a href="/" class="text-sm hover:text-emerald-400 transition-colors">Home</a>
							<a href="/blog" class="text-sm hover:text-emerald-400 transition-colors">Articles</a>
							<a href="/about" class="text-sm hover:text-emerald-400 transition-colors">About</a>
						</div>
					</div>
					<div>
						<h4 class="font-bold text-stone-300 mb-4 text-sm uppercase tracking-wider">Popular Topics</h4>
						<div class="flex flex-wrap gap-2">
							{['Budgeting', 'Saving', 'Apps', 'Investing'].map(t => (
								<span class="text-xs bg-stone-800 text-stone-400 px-3 py-1.5 rounded-full">{t}</span>
							))}
						</div>
					</div>
				</div>
				<div class="border-t border-stone-800 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
					<p class="text-xs text-stone-600">© 2026 DailyBudgetLife. All rights reserved.</p>
					<p class="text-xs text-stone-600">Built with care for your financial future.</p>
				</div>
			</div>
		</footer>
	</body>
</html>
